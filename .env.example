# ===========================================
# Sports Prediction Engine — Environment
# ===========================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Database (PostgreSQL)
POSTGRES_USER=your_username
POSTGRES_PASSWORD=your_password
POSTGRES_DB=sports_prediction_db
DATABASE_URL=postgresql://your_username:your_password@localhost:5432/sports_prediction_db

# The Odds API (https://the-odds-api.com)
# Sign up FREE at https://the-odds-api.com/# API Integrations
ODDS_API_KEY=your_api_key_here
ODDS_API_BASE_URL=https://api.the-odds-api.com/v4
API_FOOTBALL_KEY=your_api_football_key_here
API_FOOTBALL_HOST=v3.football.api-sports.io
API_FOOTBALL_BASE_URL=https://v3.football.api-sports.io

# SportAPI (RapidAPI)
SPORT_API_KEY=your_sportapi_key_here
SPORT_API_HOST=sportapi7.p.rapidapi.com
SPORT_API_BASE_URL=https://sportapi7.p.rapidapi.com/api/v1

# Backend
BACKEND_PORT=3000
NODE_ENV=development

# Frontend
FRONTEND_PORT=4200

# Email (SMTP) — for account notifications
# Leave blank for dev mode (emails logged to console)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your_email@gmail.com
# SMTP_PASS=your_app_password
# SMTP_FROM="PredictEngine" <noreply@predictengine.io>

# Live Scores Scraper (optional - enables faster live scores)
# SCRAPER_RAPIDAPI_KEY=your_flashscore_rapidapi_key
