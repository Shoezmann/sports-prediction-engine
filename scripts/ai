#!/bin/bash

BASE_URL="${API_URL:-http://localhost:3000/api}"

case "$1" in
  chat)
    shift
    curl -s -X POST "$BASE_URL/ai/chat" \
      -H "Content-Type: application/json" \
      -d "{\"prompt\": \"$*\"}" | jq -r '.response // .'
    ;;
  sports)
    shift
    curl -s -X POST "$BASE_URL/ai/chat/sports" \
      -H "Content-Type: application/json" \
      -d "{\"prompt\": \"$*\"}" | jq -r '.response // .'
    ;;
  health)
    curl -s "$BASE_URL/ai/health" | jq '.'
    ;;
  *)
    echo "Usage: ai <command> [prompt]"
    echo ""
    echo "Commands:"
    echo "  chat <prompt>     - General chat with Qwen 3.6"
    echo "  sports <prompt>   - Sports-focused AI chat"
    echo "  health            - Check AI status"
    echo ""
    echo "Examples:"
    echo "  ai chat What is ELO rating?"
    echo "  ai sports Who will win: Man City vs Liverpool?"
    exit 1
    ;;
esac